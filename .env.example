# =============================================================================
# ArgusBE environment template.
# Copy to .env.development / .env.production and fill values.
# =============================================================================

PORT=3333

# ---- Legacy / fallback JWT (kept so pre-migration tokens still verify) ------
JWT_SECRET=
JWT_EXPIRES_IN=3600s

# ---- Supabase Auth ----------------------------------------------------------
# From Supabase dashboard → Project Settings → API.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# "JWT Secret" (NOT the anon key). Used by JwtAuthGuard to verify Supabase
# access tokens. Required.
SUPABASE_JWT_SECRET=

# Where the Supabase "reset password" email link should redirect. Use the RN
# deep-link scheme in dev/production, e.g. argusrn://reset-password.
PASSWORD_RESET_REDIRECT_URL=argusrn://reset-password

# Optional — bypass RLS (dev only). Must be "false" in prod.
SUPABASE_DISABLE_RLS=false

# ---- CORS -------------------------------------------------------------------
CORS_ORIGIN=http://localhost:3000

# ---- AI / memory ------------------------------------------------------------
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5-nano
REDIS_URL=redis://localhost:6379
AI_MEMORY_TTL_SECONDS=3600
AI_MEMORY_TURNS=20

# ---- Drawer controllers (ESP32) + MQTT --------------------------------------
# Shared key ESP32 firmware sends in `X-Controller-Key` on registration.
# MVP-only: a single shared key. Move to per-controller keys before pilot.
CONTROLLER_API_KEY=prototype-shared-controller-key

# MQTT broker the backend connects to as a singleton client. Use mqtts:// +
# real credentials before pilot/production; anonymous localhost is dev-only.
MQTT_URL=mqtt://localhost:1883
MQTT_BACKEND_CLIENT_ID=argus-backend
MQTT_USERNAME=
MQTT_PASSWORD=

# How long a command may stay unresolved before the reconciler expires it.
MQTT_COMMAND_TIMEOUT_MS=15000
# A controller with no MQTT traffic for this long is treated as offline.
DRAWER_HEARTBEAT_TIMEOUT_SECONDS=90
# How often the reconciler sweeps for expired/stuck commands.
COMMAND_RECONCILE_INTERVAL_MS=10000
# ---- ElevenLabs voice (STT + TTS) -------------------------------------------
# The master key is SECRET and lives only here on the backend. It is NEVER
# shipped to the mobile app. The app calls POST /voice/elevenlabs-token to get
# short-lived single-use tokens (one for Scribe STT, one for the TTS WebSocket)
# and connects to ElevenLabs directly with those — audio never transits the BE.
ELEVENLABS_API_KEY=
# TTS model — eleven_flash_v2_5 is the lowest-latency model (recommended for
# realtime voice). Do NOT use eleven_v3 here (unsupported on stream-input).
ELEVENLABS_TTS_MODEL=eleven_flash_v2_5
# Default voice = English (British). Placeholder = ElevenLabs premade "George"
# (British). Replace with your production voiceId.
ELEVENLABS_VOICE_ID=JBFqnCBsd6RMkjVDRZzb
# STT model — Scribe v2 realtime.
ELEVENLABS_STT_MODEL=scribe_v2_realtime
# TTS output format. PCM avoids on-device MP3 decode; the app wraps PCM → WAV.
ELEVENLABS_OUTPUT_FORMAT=pcm_24000
# Default spoken language (en = English; British accent comes from the voiceId).
ELEVENLABS_DEFAULT_LANGUAGE=en
# How long the minted single-use tokens are advertised as valid (client cache
# hint, seconds). ElevenLabs single-use tokens themselves expire in ~15 min.
ELEVENLABS_TOKEN_TTL_SECONDS=60
# Base host (informational). Token minting now uses the official
# @elevenlabs/elevenlabs-js SDK, which targets the default global host so
# ElevenLabs proximity-routes each connection to the nearest cluster. The app's
# STT/TTS WebSockets also use the default global host — do NOT hardcode a
# regional host.
ELEVENLABS_API_BASE=https://api.elevenlabs.io
# Light per-user rate guard on the token-mint endpoint (mints per minute per user).
VOICE_MINT_RATE_PER_MINUTE=20
