{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "headers": [
    {
      "source": "/ai/chat/stream",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-transform" },
        { "key": "Content-Type", "value": "text/event-stream; charset=utf-8" },
        { "key": "X-Accel-Buffering", "value": "no" }
      ]
    }
  ]
}
